# ─────────────────────────────────────────────────────────────
#  Modelo de variáveis de ambiente do backend.
#  Copie para `.env` e preencha os valores. O `.env` é ignorado
#  pelo git (contém segredos); só este exemplo é versionado.
# ─────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
TZ=America/Sao_Paulo
NODE_ENV=production
PORT=3000

# ─── Banco de dados — PostgreSQL (OBRIGATÓRIO) ───────────────
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true

# ─── Auth — JWT (OBRIGATÓRIO) ────────────────────────────────
JWT_SECRET=            # use um segredo longo e aleatório
JWT_EXPIRES_IN=1d

# ─── API-Football — provedor de dados (OBRIGATÓRIO) ──────────
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=
API_FOOTBALL_MAX_DETAILED=110
API_FOOTBALL_MIN_INTERVAL_MS=300

# ─── Imagens — proxy de escudos/bandeiras ────────────────────
# URL pública do próprio backend + /api/v1/img
MEDIA_PROXY_URL=https://SEU-BACKEND.up.railway.app/api/v1/img

# ─── Crons (liga/desliga) ────────────────────────────────────
LIVE_POLLING_ENABLED=true
FOOTBALL_SYNC_ENABLED=false
CATALOG_REFRESH_ENABLED=false

# ─── Mensageria — código de validação no registro (OBRIGATÓRIO)
# RabbitMQ conecta no boot; sem ele a aplicação não sobe.
RABBITMQ_URL=
RABBITMQ_EMAIL_QUEUE=analytics.email.send
RABBITMQ_SMS_QUEUE=analytics.sms.send

# Email (nodemailer) — EMAIL_SERVICE (ex.: Gmail) OU SMTP_HOST/PORT/SECURE
EMAIL_SERVICE=Gmail
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM=

# Twilio (SMS / WhatsApp) — opcional se não enviar SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
