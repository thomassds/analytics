# App
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Railway)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true

# API-Football (provedor de dados - acesso direto via dashboard.api-football.com)
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=

# Ingestão / cron (free tier: só temporadas 2022-2024)
FOOTBALL_SYNC_ENABLED=false
FOOTBALL_SYNC_COMPETITION=1
FOOTBALL_SYNC_SEASON=2026
API_FOOTBALL_MAX_DETAILED=5
API_FOOTBALL_MIN_INTERVAL_MS=7000

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=1d

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EMAIL_QUEUE=analytics.email.send
RABBITMQ_SMS_QUEUE=analytics.sms.send


# Email (nodemailer) — EMAIL_SERVICE (ex: Gmail) ou SMTP_HOST/SMTP_PORT/SMTP_SECURE
EMAIL_SERVICE=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# Twilio (SMS / WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
